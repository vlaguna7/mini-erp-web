generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  name         String     @db.VarChar(100)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")

  company            Company?
  products           Product[]
  suppliers          Supplier[]
  clients            Client[]
  employees          Employee[]
  entries            Entry[]
  sales              Sale[]
  returns            Return[]
  productCategories      ProductCategory[]
  productBrands          ProductBrand[]
  productCollections     ProductCollection[]
  financialTransactions  FinancialTransaction[]
  recurringExpenses      RecurringExpense[]

  @@index([email], name: "idx_users_email")
  @@map("users")
}

model Company {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  name      String   @db.VarChar(100)
  cnpj      String?  @unique @db.VarChar(14)
  email     String?  @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companies")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(100)
  cnpj      String?  @db.VarChar(14)
  email     String?  @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  entries  Entry[]

  @@index([userId], name: "idx_suppliers_user_id")
  @@map("suppliers")
}

model Product {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  name          String   @db.VarChar(100)
  code          String   @db.VarChar(50)
  category      String?  @db.VarChar(100)
  quantityStock Int      @default(0) @map("quantity_stock")
  priceCost     Decimal? @map("price_cost") @db.Decimal(10, 2)
  priceSale     Decimal? @map("price_sale") @db.Decimal(10, 2)
  supplierId    Int?     @map("supplier_id")
  minStock      Int?     @map("min_stock")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  // Novos campos — Informações gerais
  unitType     String? @map("unit_type") @db.VarChar(10)
  categoryId   Int?    @map("category_id")
  brandId      Int?    @map("brand_id")
  collectionId Int?    @map("collection_id")
  barcode      String? @db.VarChar(50)
  observations String? @db.Text

  // Valores
  markup Decimal? @db.Decimal(10, 2)

  // Estoque
  maxStock Int? @map("max_stock")

  // Pesos e dimensões
  weight Decimal? @db.Decimal(10, 3)
  height Decimal? @db.Decimal(10, 2)
  width  Decimal? @db.Decimal(10, 2)
  depth  Decimal? @db.Decimal(10, 2)

  // Dados fiscais
  ncm        String? @db.VarChar(10)
  cest       String? @db.VarChar(10)
  cfop       String? @db.VarChar(10)
  icmsOrigin String? @map("icms_origin") @db.VarChar(10)
  icmsCst    String? @map("icms_cst") @db.VarChar(10)

  // E-commerce
  ecommerceActive         Boolean @default(false) @map("ecommerce_active")
  ecommerceDescription    String? @map("ecommerce_description") @db.Text
  ecommerceSeoTitle       String? @map("ecommerce_seo_title") @db.VarChar(200)
  ecommerceSeoDescription String? @map("ecommerce_seo_description") @db.VarChar(500)

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier       Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  productCategory ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productBrand   ProductBrand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)
  productCollection ProductCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  images         ProductImage[]
  saleItems      SaleItem[]
  entries        Entry[]
  returns        Return[]

  @@unique([userId, code])
  @@index([userId], name: "idx_products_user_id")
  @@index([code], name: "idx_products_code")
  @@map("products")
}

model ProductCategory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([userId, name])
  @@index([userId], name: "idx_product_categories_user_id")
  @@map("product_categories")
}

model ProductBrand {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([userId, name])
  @@index([userId], name: "idx_product_brands_user_id")
  @@map("product_brands")
}

model ProductCollection {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([userId, name])
  @@index([userId], name: "idx_product_collections_user_id")
  @@map("product_collections")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  url       String   @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], name: "idx_product_images_product_id")
  @@map("product_images")
}

model Client {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  name         String   @db.VarChar(100)
  personType   String?  @map("person_type") @db.VarChar(10)
  cpfCnpj      String?  @map("cpf_cnpj") @db.VarChar(18)
  gender       String?  @db.VarChar(20)
  birthDate    String?  @map("birth_date") @db.VarChar(10)
  phone        String?  @db.VarChar(100)
  whatsapp     String?  @db.VarChar(20)
  instagram    String?  @db.VarChar(100)
  email        String?  @db.VarChar(100)
  category     String?  @db.VarChar(50)
  photo        String?  @db.Text
  zipCode      String?  @map("zip_code") @db.VarChar(10)
  street       String?  @db.VarChar(200)
  number       String?  @db.VarChar(20)
  complement   String?  @db.VarChar(100)
  neighborhood String?  @db.VarChar(100)
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(2)
  observations String?  @db.Text
  creditBalance Decimal @default(0) @map("credit_balance") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user                         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesAsClient                Sale[]                 @relation("SaleClient")
  returns                      Return[]               @relation("ReturnClient")
  financialTransactions        FinancialTransaction[] @relation("FinancialTransactionClient")

  @@index([userId], name: "idx_clients_user_id")
  @@map("clients")
}

model Employee {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(100)
  email     String?  @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  role      String?  @db.VarChar(50)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales Sale[] @relation("SaleSeller")

  @@index([userId], name: "idx_employees_user_id")
  @@map("employees")
}

model Entry {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  productId   Int?     @map("product_id")
  supplierId  Int?     @map("supplier_id")
  type        String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  quantity    Int?
  value       Decimal  @db.Decimal(10, 2)
  entryDate   DateTime @map("entry_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_entries_user_id")
  @@map("entries")
}

model Sale {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  clientId          Int?     @map("client_id")
  sellerId          Int?     @map("seller_id")
  totalValue        Decimal  @map("total_value") @db.Decimal(10, 2)
  subtotal          Decimal  @default(0) @db.Decimal(10, 2)
  discount          Decimal  @default(0) @db.Decimal(10, 2)
  surcharge         Decimal  @default(0) @db.Decimal(10, 2)
  presenceIndicator String?  @map("presence_indicator") @db.VarChar(50)
  saleCategory      String?  @map("sale_category") @db.VarChar(50)
  observation       String?  @db.Text
  saleDate          DateTime @map("sale_date") @db.Date
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?       @relation("SaleClient", fields: [clientId], references: [id], onDelete: SetNull)
  seller   Employee?     @relation("SaleSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  items    SaleItem[]
  payments SalePayment[]
  returns  Return[]

  @@index([userId], name: "idx_sales_user_id")
  @@index([clientId], name: "idx_sales_client_id")
  @@map("sales")
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int      @map("sale_id")
  productId Int      @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId], name: "idx_sale_items_sale_id")
  @@map("sale_items")
}

model SalePayment {
  id           Int      @id @default(autoincrement())
  saleId       Int      @map("sale_id")
  method       String   @db.VarChar(20)
  label        String   @db.VarChar(100)
  amount       Decimal  @db.Decimal(10, 2)
  installments Int?
  cardBrand    String?  @map("card_brand") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId], name: "idx_sale_payments_sale_id")
  @@map("sale_payments")
}

model Return {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  saleId           Int?     @map("sale_id")
  productId        Int      @map("product_id")
  clientId         Int?     @map("client_id")
  quantity         Int
  refundValue      Decimal? @map("refund_value") @db.Decimal(10, 2)
  resolutionMethod String?  @map("resolution_method") @db.VarChar(30)
  reason           String?  @db.VarChar(255)
  returnDate       DateTime @map("return_date") @db.Date
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale    Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  client  Client? @relation("ReturnClient", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_returns_user_id")
  @@index([clientId], name: "idx_returns_client_id")
  @@map("returns")
}

model FinancialTransaction {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  clientId      Int?     @map("client_id")
  type          String   @db.VarChar(30) // DESPESA, RECEITA, RENEGOCIACAO
  category      String?  @db.VarChar(100)
  description   String   @db.VarChar(255)
  value         Decimal  @db.Decimal(10, 2)
  date          DateTime @db.Date
  paymentMethod String?  @map("payment_method") @db.VarChar(50)
  status        String   @default("PAGO") @db.VarChar(20)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation("FinancialTransactionClient", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_financial_transactions_user_id")
  @@index([clientId], name: "idx_financial_transactions_client_id")
  @@map("financial_transactions")
}

model RecurringExpense {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  description String    @db.VarChar(255)
  category    String?   @db.VarChar(100)
  value       Decimal   @db.Decimal(10, 2)
  frequency   String    @db.VarChar(20) // MENSAL, SEMANAL, QUINZENAL, ANUAL
  dayOfMonth  Int?      @map("day_of_month")
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  active      Boolean   @default(true)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_recurring_expenses_user_id")
  @@map("recurring_expenses")
}
